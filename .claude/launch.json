{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "text-converter",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{const p=require('path').join('.',require('url').parse(q.url).pathname==='/'?'index.html':require('url').parse(q.url).pathname);require('fs').readFile(p,(e,d)=>{if(e){r.writeHead(404);r.end('Not found')}else{const t={'.html':'text/html','.js':'text/javascript','.css':'text/css'}[require('path').extname(p)]||'application/octet-stream';r.writeHead(200,{'Content-Type':t});r.end(d)}})}).listen(8080)"],
      "port": 8080
    }
  ]
}
